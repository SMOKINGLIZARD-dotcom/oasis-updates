$ErrorActionPreference = "Stop"

Write-Host ""
Write-Host "=== REPAIR OREBOUND 0.1.2 MANIFEST ===" -ForegroundColor Cyan
Write-Host ""
Write-Host "IMPORTANT: Select the COMPLETE OreBound-0.1.2.zip that you will upload to GitHub." -ForegroundColor Yellow
Write-Host "Do NOT select package.zip.part from OasisUpdateCache." -ForegroundColor Yellow
Write-Host ""

try {
    $zipPath = Read-Host "Paste the full path to OreBound-0.1.2.zip"
    $zipPath = $zipPath.Trim().Trim('"')

    if (-not (Test-Path -LiteralPath $zipPath -PathType Leaf)) {
        throw "ZIP not found: $zipPath"
    }

    $file = Get-Item -LiteralPath $zipPath

    if ($file.Name -ne "OreBound-0.1.2.zip") {
        throw "The file must be named exactly OreBound-0.1.2.zip. Selected: $($file.Name)"
    }

    if ($file.Length -lt 10MB) {
        Write-Host ""
        Write-Host "WARNING: This ZIP is smaller than 10 MB." -ForegroundColor Red
        Write-Host "A full Unity build is usually much larger. Check that the ZIP contains OreBound.exe and OreBound_Data." -ForegroundColor Red
        Write-Host ""
        $answer = Read-Host "Type CONTINUE to use it anyway"
        if ($answer -cne "CONTINUE") {
            throw "Cancelled."
        }
    }

    $size = $file.Length
    $hash = (Get-FileHash -LiteralPath $zipPath -Algorithm SHA256).Hash.ToLowerInvariant()
    $outputFolder = $file.DirectoryName
    $manifestPath = Join-Path $outputFolder "orebound-manifest.json"

    $manifest = [ordered]@{
        gameId = "orebound"
        version = "0.1.2"
        packageUrl = "https://github.com/SMOKINGLIZARD-dotcom/oasis-updates/releases/download/orebound-v0.1.2/OreBound-0.1.2.zip"
        packageSize = $size
        sha256 = $hash
    }

    $json = $manifest | ConvertTo-Json
    $utf8NoBom = New-Object System.Text.UTF8Encoding($false)
    [System.IO.File]::WriteAllText($manifestPath, $json, $utf8NoBom)

    Write-Host ""
    Write-Host "SUCCESS" -ForegroundColor Green
    Write-Host ""
    Write-Host "Exact ZIP to upload/re-upload:" -ForegroundColor Cyan
    Write-Host $zipPath
    Write-Host ""
    Write-Host "Generated manifest:" -ForegroundColor Cyan
    Write-Host $manifestPath
    Write-Host ""
    Write-Host "PACKAGE SIZE:" -ForegroundColor Cyan
    Write-Host $size
    Write-Host ""
    Write-Host "SHA-256:" -ForegroundColor Cyan
    Write-Host $hash
    Write-Host ""
    Write-Host "Publish/re-upload the ZIP FIRST, then replace the repo-root manifest LAST." -ForegroundColor Yellow
}
catch {
    Write-Host ""
    Write-Host "FAILED:" -ForegroundColor Red
    Write-Host $_.Exception.Message -ForegroundColor Red
}

Write-Host ""
Read-Host "Press Enter to close"
